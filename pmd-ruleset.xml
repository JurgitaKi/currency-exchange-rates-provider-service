<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Currency Exchange PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/pmd-6.55.0/ruleset_xml_schema.xsd">

    <description>Reasonable PMD baseline for service, controller, and test code.</description>

    <rule ref="category/java/bestpractices.xml">
        <!-- SLF4J parameterized logging is already lazy; explicit guards add noise -->
        <exclude name="GuardLogStatement"/>
        <!-- Test count is a design choice; many assertions are intentional in integration tests -->
        <exclude name="JUnitTestContainsTooManyAsserts"/>
        <!-- MockMvc andExpect() is a valid assertion form; PMD does not recognize it -->
        <exclude name="JUnitTestsShouldIncludeAssert"/>
        <!-- HttpHeaders and similar Spring types are used intentionally -->
        <exclude name="LooseCoupling"/>
        <!-- Base test classes without abstract methods is a standard JUnit pattern -->
        <exclude name="AbstractClassWithoutAbstractMethod"/>
    </rule>
    <rule ref="category/java/errorprone.xml">
        <!-- Duplicate literals in annotations and test data are acceptable -->
        <exclude name="AvoidDuplicateLiterals"/>
    </rule>
    <rule ref="category/java/codestyle.xml/UnnecessaryConstructor"/>

    <exclude-pattern>.*/target/.*</exclude-pattern>
</ruleset>
